  "sources": {
    "linux_sof": {
      "local_paths": [
        "drivers/sound/soc/intel",
        "drivers/sound/soc/sof"
      ],
      "remote_url": "https://github.com/thesofproject/linux",
      "path_filter": "sound/soc/intel/**",
      "branches": ["main", "topic/sof-dev"],
      "last_audited_versions": []
    },
    "linux_hda": {
      "local_paths": [
        "drivers/sound/pci/hda",
        "drivers/sound/hda"
      ],
      "remote_url": "https://github.com/torvalds/linux",
      "path_filter": "sound/pci/hda/**",
      "branches": ["master"],
      "last_audited_versions": []
    },
    "linux_soundwire": {
      "local_paths": [
        "drivers/soundwire"
      ],
      "remote_url": "https://github.com/torvalds/linux",
      "path_filter": "drivers/soundwire/**",
      "branches": ["master"],
      "last_audited_versions": []
    },
    "ace_spec": {
      "local_path": null,
      "source_doc": "ACE 4.x Audio/Voice DSP EDS",
      "last_known_date": null
    },
    "soundwire_spec": {
      "local_path": null,
      "source_doc": "MIPI SoundWire Specification 1.2.1",
      "last_known_date": null
    },
    "check_interval_hours": 24
  },

  "self_learn": {
    "nga": {
      "enabled": true,
      "base_url": "https://nga.intel.com",
      "project_name": "NVL",
      "suite_filters": ["Audio", "ACE", "HDA", "SoundWire", "DMIC", "UAOL"],
      "lookback_days": 14
    },
    "hsdes": {
      "tenants": ["heia_soc.sighting", "heia_soc.bug"],
      "query_filters": {
        "component": ["audio", "ace", "hda", "soundwire", "dmic", "dsp", "uaol", "codec"],
        "status": ["open", "in_progress", "resolved"]
      },
      "lookback_days": 30
    },
    "feedback_file": "reports/audio_feedback.json"
  },

  "self_check": {
    "required_owner_tag": "huiyingt",
    "expected_skill_count": 17,
    "cross_ref_rules": {
      "uaol_expected_in": ["power", "config-checkout", "failure-analysis"],
      "uaol_excluded_from": ["dmic", "bt-offload"],
      "wov_expected_in": ["dmic", "power", "clocking"],
      "wov_excluded_from": ["display-audio", "uaol"]
    }
  },

  "self_verify": {
    "eval_tests_file": "eval/audio_eval_tests.json",
    "pass_threshold_pct": 95.0,
    "results_dir": "reports/eval_results"
  },

